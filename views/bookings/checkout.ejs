<% layout("/layouts/boilerplate") %>

<div class="container mt-5 mb-5">
  
  <div class="row g-5 align-items-start"> 
    
    <div class="col-md-7">
      <div class="card shadow-sm p-4 border-0 bg-white"> 
        <h3 class="mb-4 fw-bold">Confirm and Pay</h3>
        
        <form action="/listings/<%= listing._id %>/bookings" method="POST" class="needs-validation" novalidate>
            
            <h5 class="mb-3">Your Trip</h5>
            
            <div class="mb-3">
                <label for="fullName" class="form-label text-muted small fw-bold">Full Name</label>
                <input type="text" class="form-control py-2" name="booking[name]" value="<%= currUser.username %>" required>
            </div>

            <div class="mb-3">
                <label for="mobile" class="form-label text-muted small fw-bold">Mobile Number</label>
                <input 
                  type="tel" 
                  class="form-control py-2" 
                  id="mobile" 
                  name="booking[phone]" 
                  placeholder="9876543210" 
                  maxlength="10" 
                  pattern="[0-9]{10}"
                  required
                >
                <div class="invalid-feedback">Please enter a valid 10-digit number.</div>
            </div>

            <input type="hidden" name="booking[checkIn]" value="<%= dateIn %>">
            <input type="hidden" name="booking[checkOut]" value="<%= dateOut %>">
            <hr class="my-4">

            <h5 class="mb-3">Payment Details</h5>
            
            <div class="mb-3">
                <label class="form-label text-muted small fw-bold">Card Number</label>
                <input 
                  type="text" 
                  class="form-control py-2" 
                  id="cardNumber" 
                  placeholder="1234 5678 1234 5678" 
                  maxlength="16" 
                  pattern="\d{16}"
                  required
                >
            </div>

            <div class="row">
                <div class="col-6 mb-3">
                    <label class="form-label text-muted small fw-bold">Expiry</label>
                    <input 
                      type="text" 
                      class="form-control py-2" 
                      id="expiry" 
                      placeholder="MM/YY" 
                      maxlength="5" 
                      required
                    >
                </div>
                <div class="col-6 mb-3">
                    <label class="form-label text-muted small fw-bold">CVV</label>
                    <input 
                      type="password" 
                      class="form-control py-2" 
                      id="cvv" 
                      placeholder="123" 
                      maxlength="3" 
                      pattern="\d{3}"
                      required
                    >
                </div>
            </div>

            <button class="btn btn-danger w-100 btn-lg mt-3 fw-bold">Confirm & Pay</button>
        </form>
      </div>
    </div>

    <div class="col-md-5">
      <div class="card shadow-sm border rounded overflow-hidden">
        
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image" style="height: 180px; object-fit: cover;">
        
        <div class="card-body p-4">
            <h5 class="card-title fw-bold"><%= listing.title %></h5>
            <p class="text-muted small"><%= listing.location %>, <%= listing.country %></p>
            
            <hr>
            
            <div class="d-flex justify-content-between mb-2">
                <span>Check-in</span>
                <strong><%= dateIn ? dateIn.toLocaleDateString('en-IN') : 'N/A' %></strong>
            </div>
            <div class="d-flex justify-content-between mb-3">
                <span>Check-out</span>
                <strong><%= dateOut ? dateOut.toLocaleDateString('en-IN') : 'N/A' %></strong>
            </div>

            <hr>

            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted">Price per night</span>
                <span>₹ <%= listing.price.toLocaleString("en-IN") %></span>
            </div>
             <div class="d-flex justify-content-between align-items-center mt-2">
                <span class="text-muted">Total Nights</span>
                <span>x <%= totalNights %></span>
            </div>
            
            <hr>

            <div class="d-flex justify-content-between align-items-center pt-2">
                <h5 class="m-0 fw-bold">Total (INR)</h5>
                <h5 class="m-0 fw-bold">₹ <%= totalPrice.toLocaleString("en-IN") %></h5>
            </div>

        </div>
      </div>
    </div>

  </div>
</div>

<script>
  document.getElementById('mobile').addEventListener('input', function (e) {
    this.value = this.value.replace(/[^0-9]/g, '');
  });

  document.getElementById('cardNumber').addEventListener('input', function (e) {
    this.value = this.value.replace(/[^0-9]/g, '');
  });

  document.getElementById('cvv').addEventListener('input', function (e) {
    this.value = this.value.replace(/[^0-9]/g, '');
  });

  document.getElementById('expiry').addEventListener('input', function (e) {
    this.value = this.value.replace(/[^0-9\/]/g, '');
    
    if (this.value.length === 2 && !this.value.includes('/')) {
        this.value += '/';
    }
    if(this.value.length === 3 && this.value[2] !== '/') {
         this.value = this.value.slice(0, 2) + '/' + this.value.slice(2);
    }
  });
</script>