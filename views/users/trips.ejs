<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-10 offset-1">
    <h2 class="mb-4">My Trips</h2>

    <% if(bookings.length === 0) { %>
        <div class="alert alert-light text-center p-5 shadow-sm">
             <h4>No trips booked... yet!</h4>
             <p class="text-muted">Time to dust off your bags and start planning your next adventure.</p>
             <a href="/listings" class="btn btn-outline-danger mt-2">Start Searching</a>
        </div>
    <% } else { %>
        
        <div class="row">
        <% for(let booking of bookings) { %>
          
          <% if (booking.listing) { %> 

              <div class="col-12 mb-4">
                <div class="card shadow-sm overflow-hidden border-0">
                  <div class="row g-0">
                    
                    <div class="col-md-4">
                       <a href="/listings/<%= booking.listing._id %>">
                        <img src="<%= booking.listing.image.url %>" class="img-fluid h-100 w-100" alt="listing image" style="object-fit: cover; min-height: 220px;">
                       </a>
                    </div>
                    
                    <div class="col-md-8 ps-md-2">
                      <div class="card-body h-100 d-flex flex-column justify-content-between pb-4"> 
                        <div>
                            <div class="d-flex justify-content-between align-items-start">
                                <h4 class="card-title mb-1"><%= booking.listing.title %></h4>
                                <span class="badge bg-success">Confirmed</span>
                            </div>
                            <p class="text-muted small"><i class="fa-solid fa-location-dot"></i> <%= booking.listing.location %>, <%= booking.listing.country %></p>
                            
                            <div class="row mt-3 bg-light p-3 rounded mx-1">
                                <div class="col-6 border-end">
                                    <small class="text-muted text-uppercase" style="font-size: 0.75rem;">Check-In</small>
                                    <p class="fw-bold mb-0"><%= new Date(booking.checkIn).toDateString() %></p>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted text-uppercase" style="font-size: 0.75rem;">Check-Out</small>
                                    <p class="fw-bold mb-0"><%= new Date(booking.checkOut).toDateString() %></p>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                            
                            <div>
                                <span class="text-muted small">Total Price</span>
                                <h5 class="m-0 text-danger">₹ <%= booking.totalPrice.toLocaleString("en-IN") %></h5>
                            </div>

                            <div class="d-flex gap-2">
                                 <form method="POST" action="/profile/trips/<%= booking._id %>?_method=DELETE">
                                    <button class="btn btn-sm btn-danger">Cancel Trip</button>
                                 </form>
                                 
                                 <a href="/listings/<%= booking.listing._id %>" class="btn btn-sm btn-dark">View Listing</a>
                            </div>
                        </div>

                      </div>
                    </div>

                  </div>
                </div>
              </div>
          
          <% } %> <% } %>
        </div>

    <% } %>
  </div>
</div>